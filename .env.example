# Anthropic API key (required for Claude-based extraction and rendering)
ANTHROPIC_API_KEY=sk-ant-...

# Whisper model size: tiny, base, small, medium, large-v2, large-v3
# Larger = more accurate but slower. "base" is a good default for English.
WHISPER_MODEL=base

# Root directory for session output data
DATA_DIR=./data

# Directory containing style card YAML files
STYLES_DIR=./styles

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: webhook auth. If set, POST /trigger and GET /jobs require header X-TUTOR-FEEDBACK-SECRET with this value.
# TUTOR_FEEDBACK_WEBHOOK_SECRET=your-secret
